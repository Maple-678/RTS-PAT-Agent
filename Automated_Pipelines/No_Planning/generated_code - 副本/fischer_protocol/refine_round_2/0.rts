var lock = 0;
var in_cs[4] = [0,0,0,0];

P(i) = noncritical_i -> await(lock==0) {lock=1;} -> cs_i -> {in_cs[i]=1;} -> critical_i -> exit_i -> {lock=0; in_cs[i]=0;} -> P(i);

System = P(0) ||| P(1) ||| P(2) ||| P(3);

#define mutex ( (in_cs[0] + in_cs[1] + in_cs[2] + in_cs[3]) <= 1 );
#define progress ( (in_cs[0]==1) || (in_cs[1]==1) || (in_cs[2]==1) || (in_cs[3]==1) );
#assert System deadlockfree;