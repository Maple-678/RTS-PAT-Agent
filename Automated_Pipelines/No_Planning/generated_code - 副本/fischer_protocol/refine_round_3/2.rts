var lock = false;
var in_cs[4] = [0,0,0,0];

P(i) = noncritical_i -> [lock == false] { lock = true; } -> {in_cs[i]=1;} -> critical_i -> exit_i -> {lock = false; in_cs[i]=0;} -> P(i);

System = P(0) ||| P(1) ||| P(2) ||| P(3);

#define mutex ( (in_cs[0] + in_cs[1] + in_cs[2] + in_cs[3]) <= 1 );
#define progress ( (in_cs[0]==1) || (in_cs[1]==1) || (in_cs[2]==1) || (in_cs[3]==1) );
#assert System |= []<>progress;