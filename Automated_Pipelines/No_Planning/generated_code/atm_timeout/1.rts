var ejected = false;
#define card_ejected_state (ejected == true);

ATM() = card_insert -> (pin_input -> transaction -> Stop) timeout[8] (card_ejected{ejected = true;} -> Stop);
User() = card_insert -> (pin_input -> Stop) timeout[9] Stop;
System() = ATM() || User();

#assert System() reaches card_ejected_state;