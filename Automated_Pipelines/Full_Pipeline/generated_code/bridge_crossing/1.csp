#define MAX_CROSSING_TIME 17;
#define KNIGHT_TIME 1;
#define LADY_TIME 2;
#define KING_TIME 5;
#define QUEEN_TIME 10;
#define POSITION_SOUTH 0;
#define POSITION_NORTH 1;
var elapsedTime = 0;
var knightPosition = POSITION_SOUTH;
var ladyPosition = POSITION_SOUTH;
var kingPosition = POSITION_SOUTH;
var queenPosition = POSITION_SOUTH;

South() =
	[knightPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && kingPosition == POSITION_SOUTH && ladyPosition == POSITION_SOUTH && elapsedTime == 0]cross_one_knight{knightPosition = POSITION_NORTH; elapsedTime = 1;} -> North()
	[] [knightPosition == POSITION_SOUTH && ladyPosition == POSITION_SOUTH && kingPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && elapsedTime == 0]cross_one_lady{ladyPosition = POSITION_NORTH; elapsedTime = 2;} -> North()
	[] [knightPosition == POSITION_SOUTH && ladyPosition == POSITION_SOUTH && kingPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && elapsedTime == 0]cross_one_king{kingPosition = POSITION_NORTH; elapsedTime = 5;} -> North()
	[] [knightPosition == POSITION_SOUTH && ladyPosition == POSITION_SOUTH && kingPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && elapsedTime == 0]cross_one_queen{queenPosition = POSITION_NORTH; elapsedTime = 10;} -> North()
	[] [knightPosition == POSITION_SOUTH && ladyPosition == POSITION_SOUTH && elapsedTime == 0]cross_knight_and_lady{knightPosition = POSITION_NORTH; ladyPosition = POSITION_NORTH; elapsedTime = 2;} -> North()
	[] [knightPosition == POSITION_SOUTH && kingPosition == POSITION_SOUTH && elapsedTime == 0]cross_knight_and_king{knightPosition = POSITION_NORTH; kingPosition = POSITION_NORTH; elapsedTime = 5;} -> North()
	[] [knightPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && elapsedTime == 0]cross_knight_and_queen{knightPosition = POSITION_NORTH; queenPosition = POSITION_NORTH; elapsedTime = 10;} -> North()
	[] [ladyPosition == POSITION_SOUTH && kingPosition == POSITION_SOUTH && elapsedTime == 0]cross_lady_and_king{ladyPosition = POSITION_NORTH; kingPosition = POSITION_NORTH; elapsedTime = 5;} -> North()
	[] [ladyPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && elapsedTime == 0]cross_lady_and_queen{ladyPosition = POSITION_NORTH; queenPosition = POSITION_NORTH; elapsedTime = 10;} -> North()
	[] [kingPosition == POSITION_SOUTH && queenPosition == POSITION_SOUTH && elapsedTime == 0]cross_king_and_queen{kingPosition = POSITION_NORTH; queenPosition = POSITION_NORTH; elapsedTime = 10;} -> North();

North() =
	[knightPosition == POSITION_NORTH && elapsedTime < 17]return_knight{knightPosition = POSITION_SOUTH; elapsedTime = 1;} -> South()
	[] [ladyPosition == POSITION_NORTH && elapsedTime < 17]return_lady{ladyPosition = POSITION_SOUTH; elapsedTime = 2;} -> South()
	[] [kingPosition == POSITION_NORTH && elapsedTime < 17]return_king{kingPosition = POSITION_SOUTH; elapsedTime = 5;} -> South()
	[] [queenPosition == POSITION_NORTH && elapsedTime < 17]return_queen{queenPosition = POSITION_SOUTH; elapsedTime = 10;} -> South()
	[] [knightPosition == POSITION_NORTH && ladyPosition == POSITION_NORTH && elapsedTime < 17]return_knight_and_lady{knightPosition = POSITION_SOUTH; ladyPosition = POSITION_SOUTH; elapsedTime = 2;} -> South()
	[] [knightPosition == POSITION_NORTH && kingPosition == POSITION_NORTH && elapsedTime < 17]return_knight_and_king{knightPosition = POSITION_SOUTH; kingPosition = POSITION_SOUTH; elapsedTime = 5;} -> South()
	[] [knightPosition == POSITION_NORTH && queenPosition == POSITION_NORTH && elapsedTime < 17]return_knight_and_queen{knightPosition = POSITION_SOUTH; queenPosition = POSITION_SOUTH; elapsedTime = 10;} -> South()
	[] [ladyPosition == POSITION_NORTH && kingPosition == POSITION_NORTH && elapsedTime < 17]return_lady_and_king{ladyPosition = POSITION_SOUTH; kingPosition = POSITION_SOUTH; elapsedTime = 5;} -> South()
	[] [ladyPosition == POSITION_NORTH && queenPosition == POSITION_NORTH && elapsedTime < 17]return_lady_and_queen{ladyPosition = POSITION_SOUTH; queenPosition = POSITION_SOUTH; elapsedTime = 10;} -> South()
	[] [kingPosition == POSITION_NORTH && queenPosition == POSITION_NORTH && elapsedTime < 17]return_king_and_queen{kingPosition = POSITION_SOUTH; queenPosition = POSITION_SOUTH; elapsedTime = 10;} -> South();

#define goal (knightPosition == POSITION_NORTH && ladyPosition == POSITION_NORTH && kingPosition == POSITION_NORTH && queenPosition == POSITION_NORTH);
#define alter ((knightPosition == POSITION_NORTH && ladyPosition == POSITION_NORTH && kingPosition == POSITION_NORTH && queenPosition == POSITION_NORTH && elapsedTime > 17) || !(knightPosition == POSITION_NORTH && ladyPosition == POSITION_NORTH && kingPosition == POSITION_NORTH && queenPosition == POSITION_NORTH));
#assert South() reaches goal with min(elapsedTime);