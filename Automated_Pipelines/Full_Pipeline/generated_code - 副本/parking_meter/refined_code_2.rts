#define paidDuration 5;
#define gracePeriod 2;
#define VIOLATION_NONE 0;
#define VIOLATION_PENDING 1;
#define VIOLATION_ISSUED 2;

var timeRemaining = 0;
var violationStatus = VIOLATION_NONE;

Meter() = pay -> {timeRemaining = paidDuration; violationStatus = VIOLATION_NONE;} -> Wait[paidDuration]; Expired();

Expired() = expire -> {timeRemaining = 0;} -> WaitForReset();

WaitForReset() = tick -> WaitForReset() [] reset -> Meter();

Enforcement() = tick -> Enforcement()
               []
               expire -> {violation